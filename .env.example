# Alphaforge 环境变量模板
# 用法：cp .env.example .env  然后按需填上面对应的 key
# .env 已经被 .gitignore 忽略，绝不会被提交。

# ---------- 数据源 ----------
# Tushare Pro token（M1 数据层用）
# 注册 https://tushare.pro/register → 个人主页 → 复制 token
TUSHARE_TOKEN=""

# 数据湖根目录（可选，默认 <project_root>/data_lake/）
# ALPHAFORGE_DATA_LAKE="/mnt/big-disk/alphaforge_data_lake"

# ---------- M5: 通知通道 ----------
# 飞书自定义机器人 webhook（推荐）
# 群里 → 设置 → 群机器人 → 添加自定义机器人
FEISHU_WEBHOOK=""
# 仅当机器人开了"签名校验"时填
FEISHU_SIGN_SECRET=""

# 企业微信群机器人 webhook
WECOM_WEBHOOK=""

# QQ 通过 OneBot v11（如 NapCat / Lagrange / go-cqhttp）
QQ_ACCESS_TOKEN=""

# ---------- M5: LLM 策略解释 ----------
# DeepSeek（推荐，便宜中文好）
# https://platform.deepseek.com/ → API keys
DEEPSEEK_API_KEY=""

# Claude（Anthropic）
ANTHROPIC_API_KEY=""

# OpenAI 兼容（通义千问 / Kimi / 智谱 / 本地 Ollama 任选）
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# 阿里通义千问（dashscope OpenAI 兼容模式）
DASHSCOPE_API_KEY=""
